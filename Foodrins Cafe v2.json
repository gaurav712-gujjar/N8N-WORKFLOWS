        "jsCode": "const msg = $input.item.json;\nconst text = msg?.message?.text || '';\nconst chatId = msg?.message?.chat?.id || '';\nconst firstName = msg?.message?.from?.first_name || 'Customer';\n\nreturn [{\n  json: {\n    message_text: text,\n    chat_id: chatId,\n    first_name: firstName\n  }\n}];"
      },
